module examples.minimal.m18_vec_methods

// Minimal 0.1 — method-style Vec (receiver mono; PROMOTE method thin).
// `v.push(x)` peels Vec<int> → specializes Vec.push without explicit type args.
import std.alloc.vec as vec

func main(): int {
    let mut v = vec.new<int>()
    if !v.is_empty() {
        return 90
    }
    v.push(10)
    v.push(20)
    v.push(30)
    if !v.put(1, 5) {
        v.destroy()
        return 1
    }
    let n = v.len() as int
    let g0 = v.get(0)
    let g1 = v.get(1)
    let g2 = v.get(2)
    match g0 {
        Some(a) => {
            match g1 {
                Some(b) => {
                    match g2 {
                        Some(c) => {
                            let p = v.pop()
                            match p {
                                Some(last) => {
                                    // 10+5+30+3+30 = 78 (same checksum as free-func m13)
                                    v.destroy()
                                    return a + b + c + n + last
                                }
                                None => {
                                    v.destroy()
                                    return 2
                                }
                            }
                        }
                        None => {
                            v.destroy()
                            return 3
                        }
                    }
                }
                None => {
                    v.destroy()
                    return 4
                }
            }
        }
        None => {
            v.destroy()
            return 5
        }
    }
}
