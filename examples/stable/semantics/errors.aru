module examples.stable.semantics.errors

import err
import io

func readName(path: str) : Result<str, Err> {
    if path == "" {
        return Result.Err(err.new("missingPath"))
    }

    return Result.Ok("Bruno")
}

func main() {
    let name, e = readName("user.txt")
    if e != nil {
        io.println("error")
        return
    }
    io.println("name=${name}")
}
