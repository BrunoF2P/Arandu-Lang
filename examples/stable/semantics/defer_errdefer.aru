module examples.stable.semantics.deferErrdefer

import io

func writeReport(path: str) : Result<void, Err> {
    let file, err = io.create(path)
    if err != nil {
        return Result.Err(err)
    }

    defer file.close()
    errdefer io.remove(path)

    let writeErr = file.write("ok")
    if writeErr != nil {
        return Result.Err(writeErr)
    }

    return nil
}