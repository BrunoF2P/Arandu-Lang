module examples.stable.syntax.functions

import err
import io

func add(a: int, b: int) : int {
    return a + b
}

func divide(a: int, b: int) : Result<int, Err> {
    if b == 0 {
        return Result.Err(err.new("divisionByZero"))
    }

    return Result.Ok(a / b)
}

func main() {
    let value = add(20, 22)
    io.println("functions ok")
}
