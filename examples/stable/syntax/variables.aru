module examples.stable.syntax.variables

import io

func main() {
    let name: str = "Bruno"
    let mut age: int = 25
    let mut score = 1_000
    let ratio = 3.14
    let active = true

    set age = age + 1
    set score = score + 50

    // Non-str interpolation requires Display/to_str (not yet); print str only.
    io.println(name)
}
