module std.alloc.vec

/// Minimal 0.1 — **IN optional** growable array (`Vec<T>`).
///
/// # Design (PROMOTE-L6 complete for Vec thin)
/// Contiguous pure-buffer storage: host raw allocators
/// (`ar_vec_malloc` / `ar_vec_realloc` / `ar_vec_buf_free`) + typed access via
/// mem intrinsics (`sizeOf` / `ptrOffset` / `ptrRead` / `ptrWrite`).
///
/// **Free-function API** (product surface for Minimal; method-style `v.push`
/// remains post-L6 / method mono). Nested free-func mono uses worklist
/// specialization (`push` → `ensure_capacity`).
///
/// Growth: geometric factor 2, minimum capacity 8 (classic dynamic-array
/// amortised O(1) append; same family as Rust `Vec` / C++ `vector`).
///
/// Mut-ref field stores through free-func params need AMIR
/// `mark_local_materialized` (prune must keep the base bind).
///
/// **Not** in default `arandu new` template (optional import).
/// Sibling IN optional: `gen_arena`, `allocator_api`, method-style `v.push` (same module).

import std.core.mem as mem

extern "C" {
    func ar_vec_malloc(size: u64): ptr[u8]
    func ar_vec_buf_free(p: ptr[u8], size: u64): void
    func ar_vec_realloc(p: ptr[u8], oldSize: u64, newSize: u64): ptr[u8]
    func abort(): void
}

/// Growable contiguous buffer of `T`.
public struct Vec<T> {
    data: ptr[T]
    len: u64
    capacity: u64
}

/// Empty vector (no allocation until first `push` or `reserve` / `with_capacity`).
public func new<T>(): Vec<T> {
    return Vec<T> {
        data: nil,
        len: 0 as u64,
        capacity: 0 as u64,
    }
}

/// Empty vector with room for at least `cap` elements (may over-allocate).
public func with_capacity<T>(cap: u64): Vec<T> {
    let mut v = new<T>()
    ensure_capacity<T>(v, cap)
    return v
}

/// Ensure absolute capacity ≥ `minCap` (internal; used by push / with_capacity).
func ensure_capacity<T>(mut v: Vec<T>, minCap: u64): void {
    if v.capacity >= minCap {
        return
    }
    let mut newCap: u64 = v.capacity
    if newCap == 0 {
        newCap = 8 as u64
    }
    while newCap < minCap {
        newCap = newCap * 2
    }
    let elem = mem.sizeOf<T>()
    let oldBytes = v.capacity * elem
    let newBytes = newCap * elem
    unsafe {
        let nullp: ptr[u8] = nil
        let p = ar_vec_realloc(v.data as ptr[u8], oldBytes, newBytes)
        if p == nullp {
            abort()
        }
        v.data = p as ptr[T]
        v.capacity = newCap
    }
}

/// Reserve room for at least `additional` more elements beyond `len`.
///
/// Mirrors Rust `Vec::reserve`: ensures `capacity >= len + additional`.
public func reserve<T>(mut v: Vec<T>, additional: u64): void {
    let need = v.len + additional
    ensure_capacity<T>(v, need)
}

/// Append `value` (amortized O(1)).
public func push<T>(mut v: Vec<T>, value: T): void {
    let need = v.len + 1
    if v.capacity < need {
        ensure_capacity<T>(v, need)
    }
    unsafe {
        let dest = mem.ptrOffset<T>(v.data, v.len as i32)
        mem.ptrWrite<T>(dest, value)
    }
    v.len = v.len + 1
}

/// Remove last element, or `None` if empty.
public func pop<T>(mut v: Vec<T>): Option<T> {
    if v.len == 0 {
        return Option.None
    }
    v.len = v.len - 1
    unsafe {
        let elemPtr = mem.ptrOffset<T>(v.data, v.len as i32)
        return Option.Some(mem.ptrRead<T>(elemPtr))
    }
}

/// Element at `index`, or `None` if out of range.
public func get<T>(shared v: Vec<T>, index: u64): Option<T> {
    if index >= v.len {
        return Option.None
    }
    unsafe {
        let elemPtr = mem.ptrOffset<T>(v.data, index as i32)
        return Option.Some(mem.ptrRead<T>(elemPtr))
    }
}

/// Overwrite index; `false` if out of range.
public func put<T>(mut v: Vec<T>, index: u64, value: T): bool {
    if index >= v.len {
        return false
    }
    unsafe {
        let elemPtr = mem.ptrOffset<T>(v.data, index as i32)
        mem.ptrWrite<T>(elemPtr, value)
    }
    return true
}

/// Number of elements.
public func len<T>(shared v: Vec<T>): u64 {
    return v.len
}

/// Allocated capacity (element slots).
public func capacity<T>(shared v: Vec<T>): u64 {
    return v.capacity
}

/// `true` if `len == 0`.
public func is_empty<T>(shared v: Vec<T>): bool {
    return v.len == 0
}

/// Drop length to zero (capacity retained).
public func clear<T>(mut v: Vec<T>): void {
    v.len = 0 as u64
}

/// Deallocate the buffer and reset to empty.
///
/// Named `destroy` (not `free`) to avoid the reserved builtin `free`.
public func destroy<T>(mut v: Vec<T>): void {
    if v.capacity > 0 {
        let size = v.capacity * mem.sizeOf<T>()
        unsafe {
            ar_vec_buf_free(v.data as ptr[u8], size)
        }
        v.data = nil
        v.capacity = 0 as u64
        v.len = 0 as u64
    }
}

// ── Method-style surface (receiver mono; same bodies as free-funcs) ─────────
// Restated type params on methods (`Vec.push<T>`) share SymbolIds with the
// struct; monomorphize peels `Vec<int>` receiver → specialize without `.push<int>`.

/// Method form of [`push`].
public func Vec.push<T>(mut self, value: T): void {
    push(self, value)
}

/// Method form of [`pop`].
public func Vec.pop<T>(mut self): Option<T> {
    return pop(self)
}

/// Method form of [`get`].
public func Vec.get<T>(shared self, index: u64): Option<T> {
    return get(self, index)
}

/// Method form of [`put`].
public func Vec.put<T>(mut self, index: u64, value: T): bool {
    return put(self, index, value)
}

/// Method form of [`len`].
public func Vec.len<T>(shared self): u64 {
    return len(self)
}

/// Method form of [`capacity`].
public func Vec.capacity<T>(shared self): u64 {
    return capacity(self)
}

/// Method form of [`is_empty`].
public func Vec.is_empty<T>(shared self): bool {
    return is_empty(self)
}

/// Method form of [`reserve`].
public func Vec.reserve<T>(mut self, additional: u64): void {
    reserve(self, additional)
}

/// Method form of [`clear`].
public func Vec.clear<T>(mut self): void {
    clear(self)
}

/// Method form of [`destroy`].
public func Vec.destroy<T>(mut self): void {
    destroy(self)
}
