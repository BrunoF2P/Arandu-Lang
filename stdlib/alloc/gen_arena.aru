// arandu_alloc::gen_arena — generational slots (F2.3.runtime product surface).
//
// Minimal 0.1 — **IN optional** (PROMOTE GenArena thin, same family as Vec).
// Pure-buffer storage + free-func API; host only for raw bytes (`ar_vec_*`).
// Compiler AMIR GenInsert/GenGet/GenRemove still use host i64 MVP (`ar_gen_*`).

module std.alloc.gen_arena

import std.core.mem as mem

extern "C" {
    func ar_vec_malloc(size: u64): ptr[u8]
    func ar_vec_buf_free(p: ptr[u8], size: u64): void
    func ar_vec_realloc(p: ptr[u8], oldSize: u64, newSize: u64): ptr[u8]
    func abort(): void
}

/// Fat handle: slot index + remembered generation (8 bytes).
/// Not interchangeable with ptr[T] or &T without compiler promotion.
public struct GenRef {
    index: u32
    generation: u32
}

/// Recyclable generational arena (slab free list + gen bump on recycle).
///
/// Layout (parallel pure buffers, like a typed slab):
/// - `data` / `gen` / `used` — slot tables, length `slots_cap`
/// - `free` — free-list of recycled indices, length `free_len`
/// - live count = `slots - free_len`
public struct GenArena<T> {
    data: ptr[T]
    gen: ptr[u32]
    used: ptr[u8]
    free: ptr[u32]
    free_len: u64
    free_cap: u64
    slots: u64
    slots_cap: u64
}

/// Empty arena (no allocation until first `insert`).
public func new<T>(): GenArena<T> {
    return GenArena<T> {
        data: nil,
        gen: nil,
        used: nil,
        free: nil,
        free_len: 0 as u64,
        free_cap: 0 as u64,
        slots: 0 as u64,
        slots_cap: 0 as u64,
    }
}

func grow_slots<T>(mut a: GenArena<T>, minCap: u64): void {
    if a.slots_cap >= minCap {
        return
    }
    let mut newCap: u64 = a.slots_cap
    if newCap == 0 {
        newCap = 8 as u64
    }
    while newCap < minCap {
        newCap = newCap * 2
    }
    let elem = mem.sizeOf<T>()
    let genElem = mem.sizeOf<u32>()
    let usedElem = mem.sizeOf<u8>()
    let oldSlots = a.slots_cap
    unsafe {
        let nullp: ptr[u8] = nil
        let pData = ar_vec_realloc(a.data as ptr[u8], oldSlots * elem, newCap * elem)
        if pData == nullp {
            abort()
        }
        let pGen = ar_vec_realloc(a.gen as ptr[u8], oldSlots * genElem, newCap * genElem)
        if pGen == nullp {
            abort()
        }
        let pUsed = ar_vec_realloc(a.used as ptr[u8], oldSlots * usedElem, newCap * usedElem)
        if pUsed == nullp {
            abort()
        }
        a.data = pData as ptr[T]
        a.gen = pGen as ptr[u32]
        a.used = pUsed as ptr[u8]
        a.slots_cap = newCap
    }
}

func grow_free<T>(mut a: GenArena<T>, minCap: u64): void {
    if a.free_cap >= minCap {
        return
    }
    let mut newCap: u64 = a.free_cap
    if newCap == 0 {
        newCap = 8 as u64
    }
    while newCap < minCap {
        newCap = newCap * 2
    }
    let genElem = mem.sizeOf<u32>()
    let oldBytes = a.free_cap * genElem
    let newBytes = newCap * genElem
    unsafe {
        let nullp: ptr[u8] = nil
        let p = ar_vec_realloc(a.free as ptr[u8], oldBytes, newBytes)
        if p == nullp {
            abort()
        }
        a.free = p as ptr[u32]
        a.free_cap = newCap
    }
}

/// Insert `value`; returns a `GenRef` valid until matching `remove` (or recycle).
public func insert<T>(mut a: GenArena<T>, value: T): GenRef {
    if a.free_len > 0 {
        a.free_len = a.free_len - 1
        unsafe {
            let freePtr = mem.ptrOffset<u32>(a.free, a.free_len as i32)
            let idx = mem.ptrRead<u32>(freePtr)
            let genPtr = mem.ptrOffset<u32>(a.gen, idx as i32)
            let oldG = mem.ptrRead<u32>(genPtr)
            let newG = oldG + 1 as u32
            mem.ptrWrite<u32>(genPtr, newG)
            let dataPtr = mem.ptrOffset<T>(a.data, idx as i32)
            mem.ptrWrite<T>(dataPtr, value)
            let usedPtr = mem.ptrOffset<u8>(a.used, idx as i32)
            mem.ptrWrite<u8>(usedPtr, 1 as u8)
            return GenRef {
                index: idx,
                generation: newG,
            }
        }
    }
    let need = a.slots + 1
    if a.slots_cap < need {
        grow_slots<T>(a, need)
    }
    let idx = a.slots as u32
    unsafe {
        let dataPtr = mem.ptrOffset<T>(a.data, idx as i32)
        mem.ptrWrite<T>(dataPtr, value)
        let genPtr = mem.ptrOffset<u32>(a.gen, idx as i32)
        mem.ptrWrite<u32>(genPtr, 0 as u32)
        let usedPtr = mem.ptrOffset<u8>(a.used, idx as i32)
        mem.ptrWrite<u8>(usedPtr, 1 as u8)
    }
    a.slots = a.slots + 1
    return GenRef {
        index: idx,
        generation: 0 as u32,
    }
}

/// Load payload; **aborts** if generation mismatches or slot is empty.
///
/// `GenRef` is taken `shared` so handles stay Copy-like (index+generation POD).
public func get<T>(shared a: GenArena<T>, shared r: GenRef): T {
    let idx = r.index as u64
    if idx >= a.slots {
        unsafe {
            abort()
        }
    }
    unsafe {
        let usedPtr = mem.ptrOffset<u8>(a.used, r.index as i32)
        let u = mem.ptrRead<u8>(usedPtr)
        if u == 0 as u8 {
            abort()
        }
        let genPtr = mem.ptrOffset<u32>(a.gen, r.index as i32)
        let g = mem.ptrRead<u32>(genPtr)
        if g != r.generation {
            abort()
        }
        let dataPtr = mem.ptrOffset<T>(a.data, r.index as i32)
        return mem.ptrRead<T>(dataPtr)
    }
}

/// Drop ownership of the slot if `r.generation` still matches; else `None`.
///
/// The caller's `GenRef` is not consumed (shared); stale re-use yields `None`.
public func remove<T>(mut a: GenArena<T>, shared r: GenRef): Option<T> {
    let idx = r.index as u64
    if idx >= a.slots {
        return Option.None
    }
    unsafe {
        let usedPtr = mem.ptrOffset<u8>(a.used, r.index as i32)
        let u = mem.ptrRead<u8>(usedPtr)
        if u == 0 as u8 {
            return Option.None
        }
        let genPtr = mem.ptrOffset<u32>(a.gen, r.index as i32)
        let g = mem.ptrRead<u32>(genPtr)
        if g != r.generation {
            return Option.None
        }
        let dataPtr = mem.ptrOffset<T>(a.data, r.index as i32)
        let val = mem.ptrRead<T>(dataPtr)
        mem.ptrWrite<u8>(usedPtr, 0 as u8)
        let needFree = a.free_len + 1
        if a.free_cap < needFree {
            grow_free<T>(a, needFree)
        }
        let freePtr = mem.ptrOffset<u32>(a.free, a.free_len as i32)
        mem.ptrWrite<u32>(freePtr, r.index)
        a.free_len = a.free_len + 1
        return Option.Some(val)
    }
}

/// Number of live (occupied) slots.
public func len<T>(shared a: GenArena<T>): u64 {
    return a.slots - a.free_len
}

/// `true` when no live slots.
public func is_empty<T>(shared a: GenArena<T>): bool {
    return len<T>(a) == 0 as u64
}

/// Deallocate all tables and reset to empty.
public func destroy<T>(mut a: GenArena<T>): void {
    if a.slots_cap > 0 {
        let elem = mem.sizeOf<T>()
        let genElem = mem.sizeOf<u32>()
        let usedElem = mem.sizeOf<u8>()
        unsafe {
            ar_vec_buf_free(a.data as ptr[u8], a.slots_cap * elem)
            ar_vec_buf_free(a.gen as ptr[u8], a.slots_cap * genElem)
            ar_vec_buf_free(a.used as ptr[u8], a.slots_cap * usedElem)
        }
        a.data = nil
        a.gen = nil
        a.used = nil
        a.slots_cap = 0 as u64
        a.slots = 0 as u64
    }
    if a.free_cap > 0 {
        let genElem = mem.sizeOf<u32>()
        unsafe {
            ar_vec_buf_free(a.free as ptr[u8], a.free_cap * genElem)
        }
        a.free = nil
        a.free_cap = 0 as u64
        a.free_len = 0 as u64
    }
}
