module std.alloc.allocator_api

/// Minimal 0.1 — **IN optional** thin allocator surface (PROMOTE allocator thin).
///
/// Free-function API (same product style as `vec` / `gen_arena`):
/// - Global heap via pure-buffer hosts (`ar_vec_*`)
/// - `BumpArena` — contiguous bump; power-of-two align; `reset` / `destroy`
///
/// Fallible paths return `Result<_, AllocError>` (custom `E` via typed return context).
/// Not in default `arandu new`.

import std.core.mem as mem

extern "C" {
    func ar_vec_malloc(size: u64): ptr[u8]
    func ar_vec_buf_free(p: ptr[u8], size: u64): void
    func ar_vec_realloc(p: ptr[u8], oldSize: u64, newSize: u64): ptr[u8]
}

/// Failure modes for fallible alloc (thin enum).
public enum AllocError {
    OutOfMemory,
    InvalidLayout,
}

/// Process-global heap tag (POD auto-copy, zero fields).
public struct GlobalAllocator {}

/// Create the global allocator tag.
public func global(): GlobalAllocator {
    return GlobalAllocator {}
}

/// Allocate `size` bytes (alignment ignored on thin host — match Vec policy).
public func global_alloc(size: u64): Result<ptr[u8], AllocError> {
    if size == 0 {
        return Result.Err(AllocError.InvalidLayout)
    }
    unsafe {
        let nullp: ptr[u8] = nil
        let p = ar_vec_malloc(size)
        if p == nullp {
            return Result.Err(AllocError.OutOfMemory)
        }
        return Result.Ok(p)
    }
}

/// Free a buffer from [`global_alloc`] / [`global_realloc`].
public func global_dealloc(p: ptr[u8], size: u64): void {
    unsafe {
        ar_vec_buf_free(p, size)
    }
}

/// Grow/shrink; on OOM returns `OutOfMemory` (original block ownership unchanged
/// only if host realloc fails without free — thin host aborts path via `Err`).
public func global_realloc(p: ptr[u8], oldSize: u64, newSize: u64): Result<ptr[u8], AllocError> {
    if newSize == 0 {
        return Result.Err(AllocError.InvalidLayout)
    }
    unsafe {
        let nullp: ptr[u8] = nil
        let q = ar_vec_realloc(p, oldSize, newSize)
        if q == nullp {
            return Result.Err(AllocError.OutOfMemory)
        }
        return Result.Ok(q)
    }
}

// ── Bump arena ────────────────────────────────────────────────────────────

/// Contiguous bump region (allocate-only until `reset` / `destroy`).
public struct BumpArena {
    buffer: ptr[u8]
    capacity: u64
    offset: u64
}

/// New bump with capacity bytes (malloc once).
public func bump_new(capacity: u64): Result<BumpArena, AllocError> {
    if capacity == 0 {
        return Result.Err(AllocError.InvalidLayout)
    }
    unsafe {
        let nullp: ptr[u8] = nil
        let p = ar_vec_malloc(capacity)
        if p == nullp {
            return Result.Err(AllocError.OutOfMemory)
        }
        return Result.Ok(BumpArena {
            buffer: p,
            capacity: capacity,
            offset: 0 as u64,
        })
    }
}

/// Bump-allocate `size` bytes with `align` (min 1).
///
/// Alignment: `ceil(off / align) * align` via integer arithmetic
/// (`((off + align - 1) / align) * align`). Works for any positive align
/// (power-of-two recommended for ABI; not required by the formula).
public func bump_alloc(mut a: BumpArena, size: u64, align: u64): Result<ptr[u8], AllocError> {
    let mut al: u64 = align
    if al == 0 {
        al = 1 as u64
    }
    let off = a.offset
    let aligned = ((off + al - 1) / al) * al
    if aligned + size > a.capacity {
        return Result.Err(AllocError.OutOfMemory)
    }
    a.offset = aligned + size
    unsafe {
        let p = mem.ptrOffset<u8>(a.buffer, aligned as i32)
        return Result.Ok(p)
    }
}

/// Reset offset to 0 (memory retained).
public func bump_reset(mut a: BumpArena): void {
    a.offset = 0 as u64
}

/// Bytes still free in the bump.
public func bump_remaining(shared a: BumpArena): u64 {
    return a.capacity - a.offset
}

/// Free the underlying buffer.
public func bump_destroy(mut a: BumpArena): void {
    if a.capacity > 0 {
        unsafe {
            ar_vec_buf_free(a.buffer, a.capacity)
        }
        a.buffer = nil
        a.capacity = 0 as u64
        a.offset = 0 as u64
    }
}
