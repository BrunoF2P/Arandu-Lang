module std.env

/// **Experimental — not Arandu Minimal 0.1.**
/// SL_S: process environment surface (signatures / host TBD).

extern "C" {
    /// Number of command-line arguments (including argv[0]).
    func args_len(): int
    /// Whether a variable name is set (host ABI; returns 0/1 as int until bool ABI).
    func var_is_set(name: str): int
}
