module std.env

/// Minimal 0.1 — **IN optional** environment query (thin, read-only).
///
/// | Function      | Status |
/// |---------------|--------|
/// | `args_len`    | host-backed (`argv` count, includes argv[0]) |
/// | `var_is_set`  | host-backed (presence, including empty value) |
///
/// **Out of Minimal:** `setenv` / `unsetenv` / listing all vars / argv strings
/// (string-return host ABI). Presence-only is intentional: no global mutation
/// races (same caution as concurrent `setenv` in C/POSIX).
///
/// Not in the default `arandu new` template.

extern "C" {
    func ar_env_args_len(): int
    /// Returns 0/1 as int (bool ABI via wrapper).
    func ar_env_var_is_set(name: str): int
}

/// Number of command-line arguments including the program name.
public func args_len(): int {
    unsafe {
        return ar_env_args_len()
    }
}

/// True if environment variable `name` is present (value may be empty).
public func var_is_set(name: str): bool {
    unsafe {
        return ar_env_var_is_set(name) != 0
    }
}
