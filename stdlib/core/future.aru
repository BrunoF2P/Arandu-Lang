// arandu_core::future — Poll surface for A3 + Minimal 0.1.
//
// Minimal 0.1 **IN**: `Poll<T>` only.
// Experimental: Waker/Context live in `std.runtime` (not this module).
// Full `Future.poll` trait: post-Minimal.

module std.core.future

/// Result of one poll step on a coroutine / future.
public enum Poll<T> {
    Ready(T)
    Pending
}
