module std.core.option

extern "C" {
    func abort(): void
}

public enum Option<T> {
    Some(T),
    None,
}

/// Unwrap Some or abort.
public func Option.expectOrAbort<T>(shared self, reason: str): T {
    match self {
        Some(v) => {
            return v
        }
        None => {
            unsafe {
                abort()
            }
        }
    }
}
