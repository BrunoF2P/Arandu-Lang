module std.core.result

extern "C" {
    func abort(): void
}

public enum Result<T, E> {
    Ok(T),
    Err(E),
}

/// Unwrap Ok or abort. Method form for ergonomics (`r.expectOrAbort("msg")`).
public func Result.expectOrAbort<T, E>(shared self, reason: str): T {
    match self {
        Ok(v) => {
            return v
        }
        Err(_) => {
            unsafe {
                abort()
            }
        }
    }
}
