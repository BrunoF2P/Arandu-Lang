module examples.stable.syntax.functions

import err
import io

func add(a int, b int) int {
    return a + b
}

func divide(a int, b int) (int, Err?) {
    if b == 0 {
        return 0, err.new("divisionByZero")
    }

    return a / b, nil
}

func main() {
    value = add(20, 22)
    io.println("value=${value}")
}
