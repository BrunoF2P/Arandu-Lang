module tests.controlFlow

func main(items: []int) {
    let index = 0
    while index < 10 {
        index += 1
        if index == 3 {
            continue
        }
        if index == 8 {
            break
        }
    }

    for item in items {
        io.println(item)
    }

    for i = 0; i < 3; i += 1 {
        io.println(i)
    }
}
