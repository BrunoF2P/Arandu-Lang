    let x_val: int = p.x

    let state: LoadState = LoadState.Loaded("hello")

    let res: int = match state {
        LoadState.Idle => 0
        LoadState.Loaded(s) => 1
    }

    let val: int = if res > 0 {
        10
    } else {
