func testAllocFree() {
    let buffer = alloc(64)
    free(buffer)
}

func testDefer(): int {
    let mut x = 0
    defer {
        x = 1
    }
    return x
}

func testDeferScope(): int {
    let mut x = 0
    if true {
        defer {
            x = x + 10
        }
        x = 5
    }
    return x
}
