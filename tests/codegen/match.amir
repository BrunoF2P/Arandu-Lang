Func test_match_expr(x: int) -> int
  locals:
    _0: int // return
    _1: int
    _2: int
    _3: int
    _4: bool
    _5: bool
    _6: bool
    _7: int
    s0: int // x
    s1: int // res

  bb0:
    switchInt _1 { 1 => bb2, otherwise => bb3 }
  bb1:
    _0 = _3
    return
  bb2:
    _3 = 10
    goto bb1
  bb3:
    _4 = ge _1, 2
    _5 = lt _1, 5
    _6 = and _4, _5
    branch _6 => bb4, else bb5
  bb4:
    _3 = 20
    goto bb1
  bb5:
    branch true => bb6, else bb7
  bb6:
    _3 = 30
    goto bb1
  bb7:
    unreachable

Func test_match_stmt(x: int) -> int
  locals:
    _0: int // return
    _1: int
    _2: int
    _3: bool
    _4: bool
    _5: bool
    _6: int
    _7: int
    s0: int // x
    s1: int // res

  bb0:
    switchInt _1 { 1 => bb2, otherwise => bb3 }
  bb1(_6: int /* from: "res" */):
    _0 = _6
    return
  bb2:
    goto bb1(10)
  bb3:
    _3 = ge _1, 2
    _4 = lt _1, 5
    _5 = and _3, _4
    branch _5 => bb4, else bb5
  bb4:
    goto bb1(20)
  bb5:
    branch true => bb6, else bb7
  bb6:
    goto bb1(30)
  bb7:
    unreachable
