Func onErr() -> void
  locals:
    _0: void // return

  bb0:
    return

Func onOk() -> void
  locals:
    _0: void // return

  bb0:
    return

Func testSuccess() -> Result<void, Err>
  locals:
    _0: Result<void, Err> // return
    _1: int
    _2: bool

  bb0:
    _0 = nil
    _1 = discriminant(_0)
    _2 = eq _1, 1
    branch _2 => bb1, else bb2
  bb1:
    call fn@onErr()
    call fn@onOk()
    return
  bb2:
    call fn@onOk()
    return

Func testError() -> Result<void, Err>
  locals:
    _0: Result<void, Err> // return
    _1: Err
    _2: int
    _3: bool

  bb0:
    _1 = call fn@err.new("interpolated")
    _0 = enumConstruct(1, _1)
    _2 = discriminant(_0)
    _3 = eq _2, 1
    branch _3 => bb1, else bb2
  bb1:
    call fn@onErr()
    call fn@onOk()
    return
  bb2:
    call fn@onOk()
    return
