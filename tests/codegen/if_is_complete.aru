enum MyResult {
    MyOk(int),
    MyError(str),
}

func makePair(): (int, int) {
    return 1, 10
}

func testTuplePattern(): int {
    let pair = makePair()
    let mut val = 0
    if pair is (x, 10) {
        val = x
    }
    return val
}

func testTypetuplePattern(res: MyResult): int {
    let mut val = 0
    if res is MyOk(x) {
        val = x
    }
    return val
}

func testRangePattern(x: int): bool {
    let mut res = false
    if x is 1..=10 {
        res = true
    }
    return res
}

func testRangeExclusive(x: int): bool {
    let mut res = false
    if x is 1..10 {
        res = true
    }
    return res
}
