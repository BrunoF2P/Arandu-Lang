enum MyResult {
    MyOk(int),
    MyError(str),
}

func make_pair(): (int, int) {
    return 1, 10
}

func test_tuple_pattern(): int {
    let pair = make_pair()
    let mut val = 0
    if pair is (x, 10) {
        val = x
    }
    return val
}

func test_typetuple_pattern(res: MyResult): int {
    let mut val = 0
    if res is MyOk(x) {
        val = x
    }
    return val
}

func test_range_pattern(x: int): bool {
    let mut res = false
    if x is 1..=10 {
        res = true
    }
    return res
}

func test_range_exclusive(x: int): bool {
    let mut res = false
    if x is 1..10 {
        res = true
    }
    return res
}
