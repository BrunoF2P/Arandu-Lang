    s1 = 0
    _2 = s0
    _3 = gt _2, 5
    switchInt _3 { 1 => bb1, otherwise => bb2 }
  bb1:
    s1 = 10
    goto bb3
  bb2:
    s1 = 20
    goto bb3
  bb3:
    _4 = s1
    _0 = _4
    return

