import err

func onErr() {
}

func onOk() {
}

func testSuccess(): Result<void, Err> {
    errdefer {
        onErr()
    }
    defer {
        onOk()
    }
    return nil
}

func testError(): Result<void, Err> {
    errdefer {
        onErr()
    }
    defer {
        onOk()
    }
    return Result.Err(err.new("boom"))
}
