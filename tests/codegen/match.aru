func test_match_expr(x: int): int {
    let res = match x {
        1 => 10
        2..5 => 20
        _ => 30
    }
    return res
}

func test_match_stmt(x: int): int {
    let mut res = 0
    match x {
        1 => {
            res = 10
        }
        2..5 => {
            res = 20
        }
        _ => {
            res = 30
        }
    }
    return res
}
