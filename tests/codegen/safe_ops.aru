func load(): Result<int, Err> {
    return Result.Ok(0)
}

func testTry(): int {
    let x = load()?
    return x * 2
}

struct Point {
    x: int
    y: int
}

func testSafeField(p: Point?): int {
    return p?.x ?? 0
}

func testSafeIndex(arr: []int, idx: int): int {
    return arr?[idx] ?? -1
}

func testNullCoalesce(a: int?, b: int): int {
    return a ?? b
}
