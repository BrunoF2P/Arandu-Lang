func test_match_expr(x int) int {
    res = match x {
        1 => 10
        2..5 => 20
        _ => 30
    }
    return res
}

func test_match_stmt(x int) int {
    res = 0
    match x {
        1 => {
            set res = 10
        }
        2..5 => {
            set res = 20
        }
        _ => {
            set res = 30
        }
    }
    return res
}
