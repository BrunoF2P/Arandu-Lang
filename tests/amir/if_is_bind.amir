Func test_bind(x: int) -> int
  locals:
    _0: int // return
    _1: int
    _2: int
    _3: int
    _4: int
    s0: int // x
    s1: int // res
    s2: int // y

  bb0:
    s0 = _1
    s1 = 0
    _2 = s0
    s2 = _2
    switchInt true { 1 => bb1, otherwise => bb2 }
  bb1:
    _3 = s2
    s1 = _3
    goto bb3
  bb2:
    s1 = 20
    goto bb3
  bb3:
