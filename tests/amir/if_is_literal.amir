Func test_literal(x: int) -> int
  locals:
    _0: int // return
    _1: int
    _2: int
    _3: bool
    _4: int
    s0: int // x
    s1: int // res

  bb0:
    s0 = _1
    s1 = 0
    _2 = s0
    _3 = eq _2, 5
    switchInt _3 { 1 => bb1, otherwise => bb2 }
  bb1:
    s1 = 10
    goto bb3
  bb2:
    s1 = 20
    goto bb3
  bb3:
    _4 = s1
    _0 = _4
    return

Func test_wildcard(x: int) -> int
  locals:
    _0: int // return
    _1: int
    _2: int
    _3: int
    s0: int // x
    s1: int // res

  bb0:
    s0 = _1
    s1 = 0
    _2 = s0
    switchInt true { 1 => bb1, otherwise => bb2 }
  bb1:
    s1 = 10
    goto bb3
  bb2:
    s1 = 20
    goto bb3
  bb3:
    _3 = s1
    _0 = _3
    return
