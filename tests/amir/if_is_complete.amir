    switchInt _6 { 1 => bb1, otherwise => bb2 }
  bb1:
    _7 = s2
    s1 = _7
    goto bb3
  bb2:
    goto bb3
  bb3:
    _8 = s1
    _0 = _8
    return

Func test_range_pattern(x: int) -> bool
  locals:
    _0: bool // return
    _1: int
    _2: int
    _3: bool
    _4: bool
    _5: bool
    _6: bool
    s0: int // x
