Func make_pair() -> (int, int)
  locals:
    _0: (int, int) // return

  bb0:
    _0 = (1, 10)
    return

Func test_tuple_pattern() -> int
  locals:
    _0: int // return
    _1: (int, int)
    _2: (int, int)
    _3: int
    _4: bool
    _5: int
    _6: bool
    _7: bool
    _8: int
    _9: int
    s0: (int, int) // pair
    s1: int // val
    s2: int // x

  bb0:
    _1 = call fn@make_pair()
    s0 = _1
    s1 = 0
    _2 = s0
    _3 = _2._0
    s2 = _3
    _4 = and true, true
    _5 = _2._1
    _6 = eq _5, 10
    _7 = and _4, _6
    switchInt _7 { 1 => bb1, otherwise => bb2 }
  bb1:
    _8 = s2
    s1 = _8
    goto bb3
  bb2:
    goto bb3
  bb3:
    _9 = s1
    _0 = _9
    return

