(* ================================================================== *)
(*  ARANDU LANGUAGE — FORMAL GRAMMAR (EBNF)                           *)
(*  Version: 0.6 candidate                                             *)
(*  Notation: ISO/IEC 14977-inspired EBNF                              *)
(* ================================================================== *)

(* ------------------------------------------------------------------ *)
(*  0. LEXER AND PARSER POLICY                                         *)
(* ------------------------------------------------------------------ *)

(*
    Source files do not require semicolons.

    The grammar uses stmt_end = ";". The lexer inserts a logical semicolon
    at a newline or EOF when the previous token can end a statement or
    expression:

        value_identifier, type_identifier, primitive type token, literal,
        ")", "]", "}", "?",
        "return", "break", "continue"

    The lexer does not insert a semicolon before ")", "]", ",",
    binary operators, ".", "?.", "?[", or after tokens that clearly continue
    an expression.

    Longest token match wins. Doc comments are recognized before normal
    line comments.

    Naming is syntactic:
        - value identifiers start lowercase or "_": user, parseJson, _tmp
        - type identifiers start uppercase: User, Vec2, Result, T
        - primitive types are lowercase keywords: int, str, bool, etc.

    This removes the ambiguity between:
        Vec2 { x: 1, y: 2 }      -- struct literal
        column { text("Oi") }   -- trailing block call

    Declaration and mutation are intentionally distinct:
        x = 10                  -- declares a new immutable binding
        mut x = 10              -- declares a new mutable binding
        set x = 20              -- mutates an existing mutable binding
        set user.name = "Ana"   -- mutates a field/place

    There is no grammar-level ambiguity between declaration and assignment.
*)

stmt_end           = ";" ;


(* ------------------------------------------------------------------ *)
(*  1. PROGRAM                                                         *)
(* ------------------------------------------------------------------ *)

program            = { stmt_end } [ module_decl ]
                     { stmt_end | top_level_decl } EOF ;

module_decl        = "module" module_path stmt_end ;

module_path        = value_identifier { "." value_identifier } ;

top_level_decl     = import_decl
                   | const_decl
                   | type_alias_decl
                   | func_decl
                   | struct_decl
                   | enum_decl
                   | interface_decl
                   | extern_decl
                   ;

visibility         = "public" ;

attribute_list     = { attribute } ;

attribute          = "@" value_identifier [ "(" [ argument_list ] ")" ] ;

const_name         = value_identifier | type_identifier ;


(* ------------------------------------------------------------------ *)
(*  2. IMPORTS                                                         *)
(* ------------------------------------------------------------------ *)

import_decl        = "import" ( module_path | named_import ) stmt_end ;

named_import       = "{" import_item { "," import_item } [ "," ] "}"
                     "from" module_path ;

import_item        = ( value_identifier | type_identifier )
                     [ "as" ( value_identifier | type_identifier ) ] ;


(* ------------------------------------------------------------------ *)
(*  3. DECLARATIONS                                                    *)
(* ------------------------------------------------------------------ *)

const_decl         = attribute_list [ visibility ] "const"
                     const_name [ type_expr ] "=" expr stmt_end ;


type_alias_decl    = attribute_list [ visibility ] "type"
                     type_identifier [ generic_params ] "=" type_expr stmt_end ;


func_decl          = attribute_list [ visibility ] [ "async" ] "func"
                     func_name [ generic_params ]
                     "(" [ param_list ] ")"
                     [ result_type ]
                     [ where_clause ]
                     block ;

func_name          = value_identifier
                   | type_name "." value_identifier
                   ;

param_list         = param { "," param } [ "," ] ;

param              = attribute_list [ ownership ] value_identifier type_expr [ "..." ] ;
                   (* semantic rule: "..." only on the last parameter. *)
                   (* semantic rule: type any is only allowed in variadic params and FFI. *)

ownership          = "own" | "mut" ;
                   (* absent ownership = safe non-owning borrow by default. *)

result_type        = type_expr | multi_result_type ;

multi_result_type  = "(" type_expr "," type_expr { "," type_expr } [ "," ] ")" ;

where_clause       = "where" where_item { "," where_item } [ "," ] ;

where_item         = type_identifier ":" constraint_list ;

constraint_list    = type_name { "+" type_name } ;


struct_decl        = attribute_list [ visibility ] "struct"
                     type_identifier [ generic_params ] [ where_clause ]
                     "{" { field_decl } "}" ;

field_decl         = attribute_list [ visibility ] value_identifier type_expr stmt_end ;


enum_decl          = attribute_list [ visibility ] "enum"
                     type_identifier [ generic_params ] [ where_clause ]
                     "{" [ enum_variant { "," enum_variant } [ "," ] ] "}" ;

enum_variant       = attribute_list type_identifier
                     [ "(" [ type_list ] ")"
                     | "{" { field_decl } "}"
                     ] ;


interface_decl     = attribute_list [ visibility ] "interface"
                     type_identifier [ generic_params ] [ where_clause ]
                     "{" { interface_member } "}" ;

interface_member   = attribute_list func_signature stmt_end ;

func_signature     = "func" value_identifier [ generic_params ]
                     "(" [ param_list ] ")" [ result_type ] [ where_clause ] ;


extern_decl        = attribute_list "extern" abi_lit "{" { extern_member } "}" ;

abi_lit            = '"' abi_name '"' ;

abi_name           = value_identifier | type_identifier ;
                   (* examples: "C", "system", "stdcall", "cdecl" *)

extern_member      = attribute_list func_signature stmt_end ;


(* ------------------------------------------------------------------ *)
(*  4. GENERICS                                                        *)
(* ------------------------------------------------------------------ *)

generic_params     = "<" generic_param { "," generic_param } [ "," ] ">" ;

generic_param      = type_identifier [ ":" constraint_list ] ;
                   (* No generic defaults in v1. *)

generic_args       = "<" type_expr { "," type_expr } [ "," ] ">" ;


(* ------------------------------------------------------------------ *)
(*  5. TYPES                                                           *)
(* ------------------------------------------------------------------ *)

type_expr          = type_primary [ "?" ] ;
                   (* T? = nullable T. Non-nullable by default. *)

type_primary       = primitive_type
                   | type_name [ generic_args ]
                   | slice_type
                   | array_type
                   | ptr_type
                   | func_type
                   | "(" type_expr ")"
                   ;

primitive_type     = "int"   | "uint"  | "float"
                   | "i8"    | "i16"   | "i32"   | "i64"
                   | "u8"    | "u16"   | "u32"   | "u64"
                   | "f32"   | "f64"
                   | "bool"  | "byte"  | "char"  | "str"
                   | "any"   | "Err"
                   ;

type_name          = [ module_path "." ] type_identifier ;

slice_type         = "[" "]" type_expr ;

array_type         = "[" int_lit "]" type_expr ;

ptr_type           = "ptr" "[" type_expr "]" ;

func_type          = "func" "(" [ type_list ] ")" [ result_type ] ;

type_list          = type_expr { "," type_expr } [ "," ] ;


(* ------------------------------------------------------------------ *)
(*  6. BLOCKS AND STATEMENTS                                           *)
(* ------------------------------------------------------------------ *)

block              = "{" { stmt_end | statement } "}" ;

statement          = var_decl stmt_end
                   | set_stmt stmt_end
                   | return_stmt stmt_end
                   | break_stmt stmt_end
                   | continue_stmt stmt_end
                   | free_stmt stmt_end
                   | expr_stmt stmt_end
                   | if_stmt
                   | for_stmt
                   | while_stmt
                   | match_stmt
                   | defer_stmt
                   | errdefer_stmt
                   | unsafe_stmt
                   ;

(*
    Declaration:
        x = 10
        mut x = 10
        name str = "Bruno"
        mut age int = 25
        file, err = open("dados.txt")

    Mutation:
        set age = age + 1
        set user.name = "Ana"
        set items[0] += 1
        set file, err = open("outro.txt")
*)

var_decl           = binding_item { "," binding_item } "=" expr ;

binding_item       = [ "mut" ] value_identifier [ type_expr ] ;

set_stmt           = "set" ( place_list "=" expr
                            | place_expr compound_assign_op expr
                            ) ;

place_list         = place_expr { "," place_expr } ;

place_expr         = value_identifier { place_suffix } ;

place_suffix       = "." value_identifier
                   | "[" expr "]"
                   ;

compound_assign_op = "+=" | "-=" | "*=" | "/=" | "%="
                   | "&=" | "|=" | "^=" | "<<=" | ">>="
                   ;

return_stmt        = "return" [ expr_list ] ;

break_stmt         = "break" ;

continue_stmt      = "continue" ;

free_stmt          = "free" expr ;

expr_stmt          = expr ;

if_stmt            = "if" condition block
                     { "else" "if" condition block }
                     [ "else" block ] ;

condition          = is_condition | expr ;

is_condition       = expr "is" pattern ;

for_stmt           = "for" for_clause block ;

for_clause         = for_binding_list "in" expr
                   | [ simple_stmt ] ";" [ expr ] ";" [ simple_stmt ]
                   ;

for_binding_list   = for_binding { "," for_binding } ;

for_binding        = [ "mut" ] value_identifier ;

simple_stmt        = var_decl
                   | set_stmt
                   | expr
                   ;

while_stmt         = "while" condition block ;

match_stmt         = "match" expr "{" { match_arm } "}" ;

match_arm          = pattern [ "if" expr ] "=>" ( expr stmt_end | block ) ;

defer_stmt         = "defer" ( expr stmt_end | block ) ;

errdefer_stmt      = "errdefer" ( expr stmt_end | block ) ;

unsafe_stmt        = "unsafe" block ;

expr_list          = expr { "," expr } [ "," ] ;


(* ------------------------------------------------------------------ *)
(*  7. PATTERNS                                                        *)
(* ------------------------------------------------------------------ *)

pattern            = "_"
                   | range_pattern
                   | enum_pattern
                   | struct_pattern
                   | tuple_pattern
                   | literal
                   | type_identifier [ "(" [ pattern_list ] ")" ]
                   | value_identifier
                   ;

pattern_list       = pattern { "," pattern } [ "," ] ;

enum_pattern       = type_name "." type_identifier [ "(" [ pattern_list ] ")" ] ;

struct_pattern     = type_name "{"
                     [ field_pattern { "," field_pattern } [ "," ] ]
                     "}" ;

field_pattern      = value_identifier [ ":" pattern ] ;

tuple_pattern      = "(" pattern "," pattern { "," pattern } [ "," ] ")" ;

range_pattern      = literal ( ".." | "..=" ) literal ;


(* ------------------------------------------------------------------ *)
(*  8. EXPRESSIONS — PRECEDENCE LOW TO HIGH                            *)
(* ------------------------------------------------------------------ *)

expr               = catch_expr ;

catch_expr         = null_coalesce_expr [ "catch" ( expr | catch_block ) ] ;

catch_block        = "|" value_identifier "|" block ;

null_coalesce_expr = logical_or_expr { "??" logical_or_expr } ;

logical_or_expr    = logical_and_expr { "||" logical_and_expr } ;

logical_and_expr   = equality_expr { "&&" equality_expr } ;

equality_expr      = comparison_expr { ( "==" | "!=" ) comparison_expr } ;

comparison_expr    = range_expr { ( "<" | ">" | "<=" | ">=" ) range_expr } ;

range_expr         = bitor_expr [ ( ".." | "..=" ) bitor_expr ] ;

bitor_expr         = bitxor_expr { "|" bitxor_expr } ;

bitxor_expr        = bitand_expr { "^" bitand_expr } ;

bitand_expr        = shift_expr { "&" shift_expr } ;

shift_expr         = additive_expr { ( "<<" | ">>" ) additive_expr } ;

additive_expr      = multiplicative_expr { ( "+" | "-" ) multiplicative_expr } ;

multiplicative_expr = cast_expr { ( "*" | "/" | "%" ) cast_expr } ;

cast_expr          = unary_expr { "as" type_expr } ;

unary_expr         = ( "!" | "-" | "~" | "await" ) unary_expr
                   | postfix_expr
                   ;

postfix_expr       = primary_expr { postfix_op } ;

postfix_op         = generic_call_suffix
                   | call_suffix
                   | field_suffix
                   | safe_field_suffix
                   | index_suffix
                   | safe_index_suffix
                   | try_suffix
                   ;

(*
    Generic arguments in expressions are accepted only as part of a call.
    This avoids misparsing comparisons like: a < b > c.
*)
generic_call_suffix = generic_args "(" [ argument_list ] ")" [ block ] ;

call_suffix        = "(" [ argument_list ] ")" [ block ] ;

field_suffix       = "." value_identifier ;

safe_field_suffix  = "?." value_identifier ;

index_suffix       = "[" expr "]" ;

safe_index_suffix  = "?[" expr "]" ;

try_suffix         = "?" ;
                   (* semantic rule: expr? works on (T, Err), Result<T>, or Option<T>. *)


(* ------------------------------------------------------------------ *)
(*  9. PRIMARY EXPRESSIONS                                             *)
(* ------------------------------------------------------------------ *)

primary_expr       = literal
                   | struct_literal
                   | array_literal
                   | lambda_expr
                   | alloc_expr
                   | async_block
                   | unsafe_block
                   | if_expr
                   | match_expr
                   | bare_block_call
                   | type_qualified_value_path
                   | value_path
                   | "(" expr ")"
                   ;

value_path         = value_identifier { "." value_identifier } ;

type_qualified_value_path = type_name "." value_identifier ;
                   (* examples: User.greet, math.Vec2.dot *)

bare_block_call    = value_path [ generic_args ] block ;
                   (* valid because value identifiers start lowercase and types start uppercase. *)
                   (* examples: column { ... }, ui.column { ... } *)

if_expr            = "if" condition block
                     { "else" "if" condition block }
                     "else" block ;

match_expr         = "match" expr "{" { match_arm } "}" ;

argument_list      = argument { "," argument } [ "," ] ;

argument           = value_identifier ":" expr
                   | expr
                   ;

struct_literal     = type_name [ generic_args ]
                     "{" [ field_init { "," field_init } [ "," ] ] "}" ;

field_init         = value_identifier ":" expr ;

array_literal      = "[" [ expr_list ] "]" ;

lambda_expr        = "(" [ lambda_params ] ")" "=>" ( expr | block ) ;

lambda_params      = lambda_param { "," lambda_param } [ "," ] ;

lambda_param       = value_identifier [ type_expr ] ;

alloc_expr         = "alloc" expr ;

async_block        = "async" block ;

unsafe_block       = "unsafe" block ;


(* ------------------------------------------------------------------ *)
(*  10. LITERALS                                                       *)
(* ------------------------------------------------------------------ *)

literal            = int_lit
                   | float_lit
                   | bool_lit
                   | char_lit
                   | string_lit
                   | nil_lit
                   ;

int_lit            = decimal_lit | hex_lit | bin_lit | oct_lit ;

decimal_lit        = nonzero_digit { digit | "_" }
                   | "0"
                   ;

hex_lit            = "0x" hex_digit { hex_digit | "_" } ;

bin_lit            = "0b" bin_digit { bin_digit | "_" } ;

oct_lit            = "0o" oct_digit { oct_digit | "_" } ;

float_lit          = decimal_lit "." digit { digit | "_" } [ float_exp ]
                   | decimal_lit float_exp
                   ;

float_exp          = ( "e" | "E" ) [ "+" | "-" ] digit { digit | "_" } ;

bool_lit           = "true" | "false" ;

nil_lit            = "nil" ;

char_lit           = "'" char_content "'" ;

char_content       = escape_seq
                   | ? any UTF-8 codepoint except single quote and backslash ?
                   ;

string_lit         = normal_str | multiline_str | raw_str ;

normal_str         = '"' { str_part } '"' ;

str_part           = str_char | escape_seq | interpolation ;

str_char           = ? any UTF-8 codepoint except double quote, backslash, and dollar ? ;

multiline_str      = '"""' { multiline_part } '"""' ;

multiline_part     = interpolation
                   | escape_seq
                   | ? any UTF-8 codepoint sequence not starting triple quote or interpolation ?
                   ;

raw_str            = "r" '"' { ? any codepoint except double quote ? } '"'
                   | "r" '"""' { ? any codepoint sequence not ending triple quote ? } '"""'
                   ;

interpolation      = "${" expr "}" ;

escape_seq         = "\\" ( "n" | "t" | "r" | "0"
                          | "\\" | '"' | "'" | "$"
                          | "u{" hex_digit { hex_digit } "}"
                          ) ;


(* ------------------------------------------------------------------ *)
(*  11. LEXICAL ELEMENTS                                               *)
(* ------------------------------------------------------------------ *)

value_identifier   = value_start { identifier_continue } ;

type_identifier    = type_start { identifier_continue } ;

value_start        = "a" .. "z" | "_" ;

type_start         = "A" .. "Z" ;

identifier_continue = "a" .. "z" | "A" .. "Z" | "0" .. "9" | "_" ;

digit              = "0" .. "9" ;

nonzero_digit      = "1" .. "9" ;

hex_digit          = digit | "a" .. "f" | "A" .. "F" ;

bin_digit          = "0" | "1" ;

oct_digit          = "0" .. "7" ;

comment            = doc_comment | line_comment | block_comment ;

doc_comment        = "///" { ? any character except newline ? } newline
                   | "/**" { ? any character sequence not ending doc block ? } "*/"
                   ;

line_comment       = "//" { ? any character except newline ? } newline ;

block_comment      = "/*" { ? any character sequence not ending block comment ? } "*/" ;

newline            = ? LF or CRLF ? ;

whitespace         = ? space, tab, newline, comments ? ;

EOF                = ? end of file ? ;


(* ------------------------------------------------------------------ *)
(*  12. RESERVED KEYWORDS                                              *)
(* ------------------------------------------------------------------ *)

(*
    if else for in while match return break continue
    func async await struct enum interface const type module import from as public
    extern unsafe where catch is set
    own mut ptr alloc free defer errdefer
    int uint float i8 i16 i32 i64 u8 u16 u32 u64 f32 f64
    bool byte char str any Err true false nil
*)

(* ================================================================== *)
(*  END OF GRAMMAR                                                     *)
(* ================================================================== *)
